---
/**
 * Typical probe split: public liveness vs authenticated admin diagnostics.
 * Paths from cadence.api.health.router (/health) and admin routers under /api/admin/.
 */
---

<div class="diagram-wrap">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 420 140"
    role="img"
    aria-labelledby="mp-title mp-desc"
    class="diagram-svg"
  >
    <title id="mp-title">Monitoring probe paths</title>
    <desc id="mp-desc">
      Load balancer uses unauthenticated GET /health; deeper checks use cadence system permissions
      on admin routes.
    </desc>
    <rect
      x="10"
      y="20"
      width="110"
      height="44"
      rx="6"
      fill="currentColor"
      fill-opacity="0.07"
      stroke="currentColor"
      stroke-width="1"></rect>
    <text
      x="65"
      y="42"
      text-anchor="middle"
      font-size="11"
      font-weight="600"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
    >
      Load balancer
    </text>
    <text
      x="65"
      y="56"
      text-anchor="middle"
      font-size="9"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
      fill-opacity="0.8"
    >
      or uptime probe
    </text>
    <path d="M125 42 L155 42" stroke="currentColor" stroke-width="1.4" fill="none"></path>
    <polygon points="155,38 165,42 155,46" fill="currentColor"></polygon>
    <rect
      x="170"
      y="18"
      width="120"
      height="48"
      rx="6"
      fill="currentColor"
      fill-opacity="0.08"
      stroke="currentColor"
      stroke-width="1.1"></rect>
    <text
      x="230"
      y="40"
      text-anchor="middle"
      font-size="11"
      font-weight="600"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
    >
      GET /health
    </text>
    <text
      x="230"
      y="56"
      text-anchor="middle"
      font-size="9"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
      fill-opacity="0.82"
    >
      No auth (liveness)
    </text>
    <rect
      x="10"
      y="88"
      width="110"
      height="44"
      rx="6"
      fill="currentColor"
      fill-opacity="0.06"
      stroke="currentColor"
      stroke-width="1"
      stroke-dasharray="4 3"></rect>
    <text
      x="65"
      y="110"
      text-anchor="middle"
      font-size="11"
      font-weight="600"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
    >
      Ops / SRE
    </text>
    <text
      x="65"
      y="124"
      text-anchor="middle"
      font-size="9"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
      fill-opacity="0.8"
    >
      Bearer + system perms
    </text>
    <path d="M125 110 L155 110" stroke="currentColor" stroke-width="1.4" fill="none"></path>
    <polygon points="155,106 165,110 155,114" fill="currentColor"></polygon>
    <rect
      x="170"
      y="86"
      width="240"
      height="48"
      rx="6"
      fill="currentColor"
      fill-opacity="0.06"
      stroke="currentColor"
      stroke-width="1.1"
      stroke-dasharray="4 3"></rect>
    <text
      x="290"
      y="108"
      text-anchor="middle"
      font-size="11"
      font-weight="600"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
    >
      GET /api/admin/health
    </text>
    <text
      x="290"
      y="124"
      text-anchor="middle"
      font-size="9"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
      fill-opacity="0.82"
    >
      Pool stats, deeper checks — cadence:system:*
    </text>
  </svg>
  <p class="diagram-caption">
    Health router: <code>cadence.api.health.router</code>. Admin paths require the permissions
    listed in{' '}
    <a href="/guides/monitoring/">Monitoring</a>.
  </p>
</div>

<style>
  @layer starlight.components {
    .diagram-wrap {
      color: var(--sl-color-gray-2);
      margin: 0.75rem 0 1.25rem;
    }

    .diagram-svg {
      display: block;
      width: 100%;
      max-width: 32rem;
      height: auto;
    }

    .diagram-caption {
      margin: 0.5rem 0 0;
      font-size: var(--sl-text-sm);
      color: var(--sl-color-gray-4);
      max-width: 36rem;
    }

    .diagram-caption code {
      font-size: 0.92em;
    }
  }
</style>
