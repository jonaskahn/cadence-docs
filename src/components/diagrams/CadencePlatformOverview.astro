---
/**
 * High-level components and data stores. Aligns with product copy in concepts/what-is-cadence.
 * Routers: src/cadence/core/router.py — infrastructure wired in lifespan (core/lifespan.py).
 */
---

<div class="diagram-wrap">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 440 260"
    role="img"
    aria-labelledby="plat-title plat-desc"
    class="diagram-svg"
  >
    <title id="plat-title">Cadence platform overview</title>
    <desc id="plat-desc">
      Clients connect to the Cadence FastAPI service, which uses PostgreSQL, Redis, and optional
      RabbitMQ.
    </desc>
    <rect
      x="12"
      y="12"
      width="416"
      height="88"
      rx="8"
      fill="currentColor"
      fill-opacity="0.06"
      stroke="currentColor"
      stroke-width="1.25"></rect>
    <text
      x="220"
      y="40"
      text-anchor="middle"
      font-size="13"
      font-weight="600"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
    >
      Cadence API (FastAPI)
    </text>
    <text
      x="220"
      y="62"
      text-anchor="middle"
      font-size="11"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
      fill-opacity="0.9"
    >
      Auth / tenant middleware · Tenant APIs · Chat / engine
    </text>
    <text
      x="220"
      y="82"
      text-anchor="middle"
      font-size="11"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
      fill-opacity="0.9"
    >
      Plugins · Orchestrator pool
    </text>

    <rect
      x="12"
      y="118"
      width="128"
      height="56"
      rx="6"
      fill="currentColor"
      fill-opacity="0.05"
      stroke="currentColor"
      stroke-width="1"></rect>
    <text
      x="76"
      y="144"
      text-anchor="middle"
      font-size="12"
      font-weight="600"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
    >
      PostgreSQL
    </text>
    <text
      x="76"
      y="162"
      text-anchor="middle"
      font-size="10"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
      fill-opacity="0.85"
    >
      Primary data
    </text>

    <rect
      x="156"
      y="118"
      width="128"
      height="56"
      rx="6"
      fill="currentColor"
      fill-opacity="0.05"
      stroke="currentColor"
      stroke-width="1"></rect>
    <text
      x="220"
      y="144"
      text-anchor="middle"
      font-size="12"
      font-weight="600"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
    >
      Redis
    </text>
    <text
      x="220"
      y="162"
      text-anchor="middle"
      font-size="10"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
      fill-opacity="0.85"
    >
      Sessions · limits
    </text>

    <rect
      x="300"
      y="118"
      width="128"
      height="56"
      rx="6"
      fill="currentColor"
      fill-opacity="0.05"
      stroke="currentColor"
      stroke-width="1"
      stroke-dasharray="4 3"></rect>
    <text
      x="364"
      y="144"
      text-anchor="middle"
      font-size="12"
      font-weight="600"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
    >
      RabbitMQ
    </text>
    <text
      x="364"
      y="162"
      text-anchor="middle"
      font-size="10"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
      fill-opacity="0.85"
    >
      Optional events
    </text>

    <rect
      x="12"
      y="192"
      width="416"
      height="52"
      rx="6"
      fill="currentColor"
      fill-opacity="0.04"
      stroke="currentColor"
      stroke-width="1"></rect>
    <text
      x="220"
      y="216"
      text-anchor="middle"
      font-size="11"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
    >
      Clients: browser / BFF · scripts · integrations
    </text>
    <text
      x="220"
      y="234"
      text-anchor="middle"
      font-size="10"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
      fill-opacity="0.85"
    >
      HTTPS to Cadence; CORS configured via environment
    </text>
  </svg>
  <p class="diagram-caption">
    Logical view; router modules are registered in <code
      >cadence.core.router.register_api_routers</code
    >.
  </p>
</div>

<style>
  @layer starlight.components {
    .diagram-wrap {
      color: var(--sl-color-gray-2);
      margin: 0.75rem 0 1.25rem;
    }

    .diagram-svg {
      display: block;
      width: 100%;
      max-width: 30rem;
      height: auto;
    }

    .diagram-caption {
      margin: 0.5rem 0 0;
      font-size: var(--sl-text-sm);
      color: var(--sl-color-gray-4);
      max-width: 34rem;
    }

    .diagram-caption code {
      font-size: 0.92em;
    }
  }
</style>
