---
/**
 * Inbound order matches Starlette/FastAPI: last registered middleware runs first on the request.
 * Registration in cadence.main: CORS → security headers → rate → tenant → auth → error handlers.
 * Source: src/cadence/main.py (configure_* calls and comments).
 */
---

<div class="diagram-wrap">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 420 300"
    role="img"
    aria-labelledby="mw-title mw-desc"
    class="diagram-svg"
  >
    <title id="mw-title">Inbound middleware stack (first layer at top)</title>
    <desc id="mw-desc">
      Request enters at ErrorHandlerMiddleware, then AuthenticationMiddleware,
      TenantContextMiddleware, RateLimitMiddleware, security headers, and CORS, matching
      cadence.main registration order inverted for inbound traffic.
    </desc>
    <defs>
      <marker id="arrowhead" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
        <path d="M0,0 L8,4 L0,8 z" fill="currentColor"></path>
      </marker>
    </defs>
    <rect
      x="8"
      y="4"
      width="404"
      height="36"
      rx="6"
      fill="currentColor"
      fill-opacity="0.08"
      stroke="currentColor"
      stroke-width="1.25"></rect>
    <text
      x="210"
      y="28"
      text-anchor="middle"
      font-size="13"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
    >
      Client (HTTP)
    </text>
    <line
      x1="210"
      y1="40"
      x2="210"
      y2="52"
      stroke="currentColor"
      stroke-width="1.5"
      marker-end="url(#arrowhead)"></line>

    <rect
      x="24"
      y="56"
      width="372"
      height="32"
      rx="5"
      fill="currentColor"
      fill-opacity="0.06"
      stroke="currentColor"
      stroke-width="1"></rect>
    <text
      x="210"
      y="77"
      text-anchor="middle"
      font-size="12"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
    >
      ErrorHandlerMiddleware
    </text>
    <line
      x1="210"
      y1="88"
      x2="210"
      y2="100"
      stroke="currentColor"
      stroke-width="1.5"
      marker-end="url(#arrowhead)"></line>

    <rect
      x="24"
      y="104"
      width="372"
      height="32"
      rx="5"
      fill="currentColor"
      fill-opacity="0.06"
      stroke="currentColor"
      stroke-width="1"></rect>
    <text
      x="210"
      y="125"
      text-anchor="middle"
      font-size="12"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
    >
      AuthenticationMiddleware
    </text>
    <line
      x1="210"
      y1="136"
      x2="210"
      y2="148"
      stroke="currentColor"
      stroke-width="1.5"
      marker-end="url(#arrowhead)"></line>

    <rect
      x="24"
      y="152"
      width="372"
      height="32"
      rx="5"
      fill="currentColor"
      fill-opacity="0.06"
      stroke="currentColor"
      stroke-width="1"></rect>
    <text
      x="210"
      y="173"
      text-anchor="middle"
      font-size="12"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
    >
      TenantContextMiddleware
    </text>
    <line
      x1="210"
      y1="184"
      x2="210"
      y2="196"
      stroke="currentColor"
      stroke-width="1.5"
      marker-end="url(#arrowhead)"></line>

    <rect
      x="24"
      y="200"
      width="372"
      height="32"
      rx="5"
      fill="currentColor"
      fill-opacity="0.06"
      stroke="currentColor"
      stroke-width="1"></rect>
    <text
      x="210"
      y="221"
      text-anchor="middle"
      font-size="12"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
    >
      RateLimitMiddleware
    </text>
    <line
      x1="210"
      y1="232"
      x2="210"
      y2="244"
      stroke="currentColor"
      stroke-width="1.5"
      marker-end="url(#arrowhead)"></line>

    <rect
      x="24"
      y="248"
      width="180"
      height="28"
      rx="5"
      fill="currentColor"
      fill-opacity="0.05"
      stroke="currentColor"
      stroke-width="1"></rect>
    <text
      x="114"
      y="266"
      text-anchor="middle"
      font-size="11"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
    >
      Security headers
    </text>
    <rect
      x="216"
      y="248"
      width="180"
      height="28"
      rx="5"
      fill="currentColor"
      fill-opacity="0.05"
      stroke="currentColor"
      stroke-width="1"></rect>
    <text
      x="306"
      y="266"
      text-anchor="middle"
      font-size="11"
      font-family="var(--sl-font, ui-sans-serif, system-ui)"
      fill="currentColor"
    >
      CORS
    </text>
  </svg>
  <p class="diagram-caption">
    Inbound order (top first). Registration order in <code>cadence.main</code> is the reverse; see{
      ' '
    }
    <a href="/concepts/how-it-works/#middleware-chain">Middleware chain</a>.
  </p>
</div>

<style>
  @layer starlight.components {
    .diagram-wrap {
      color: var(--sl-color-gray-2);
      margin: 0.75rem 0 1.25rem;
    }

    .diagram-svg {
      display: block;
      width: 100%;
      max-width: 28rem;
      height: auto;
    }

    .diagram-caption {
      margin: 0.5rem 0 0;
      font-size: var(--sl-text-sm);
      color: var(--sl-color-gray-4);
      max-width: 32rem;
    }

    .diagram-caption code {
      font-size: 0.92em;
    }
  }
</style>
