---
/**
 * Static env configuration path. Source: cadence.core.config.AppSettings (Pydantic BaseSettings, env_prefix CADENCE_).
 * Loaded once: cadence.main uses AppSettings() at import time.
 */
---

<div class="diagram-wrap">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 440 120"
    role="img"
    aria-labelledby="as-title as-desc"
    class="diagram-svg"
  >
    <title id="as-title">Environment variables to AppSettings</title>
    <desc id="as-desc">
      Process environment variables with prefix CADENCE are loaded into AppSettings once at startup.
    </desc>
    <defs>
      <marker id="as-arr" markerWidth="7" markerHeight="7" refX="6" refY="3.5" orient="auto">
        <polygon points="0 0, 7 3.5, 0 7" fill="currentColor"></polygon>
      </marker>
    </defs>
    <rect
      x="8"
      y="28"
      width="120"
      height="64"
      rx="6"
      fill="currentColor"
      fill-opacity="0.07"
      stroke="currentColor"
      stroke-width="1.1"></rect>
    <text
      x="68"
      y="56"
      text-anchor="middle"
      font-size="11"
      font-weight="600"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
    >
      Environment
    </text>
    <text
      x="68"
      y="74"
      text-anchor="middle"
      font-size="10"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
      fill-opacity="0.9"
    >
      CADENCE_* vars
    </text>
    <text
      x="68"
      y="88"
      text-anchor="middle"
      font-size="9"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
      fill-opacity="0.75"
    >
      .env optional
    </text>
    <path
      d="M132 60 L168 60"
      stroke="currentColor"
      stroke-width="1.5"
      fill="none"
      marker-end="url(#as-arr)"></path>
    <rect
      x="176"
      y="20"
      width="160"
      height="80"
      rx="6"
      fill="currentColor"
      fill-opacity="0.06"
      stroke="currentColor"
      stroke-width="1.1"></rect>
    <text
      x="256"
      y="48"
      text-anchor="middle"
      font-size="12"
      font-weight="600"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
    >
      AppSettings
    </text>
    <text
      x="256"
      y="66"
      text-anchor="middle"
      font-size="10"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
      fill-opacity="0.88"
    >
      cadence.core.config
    </text>
    <text
      x="256"
      y="84"
      text-anchor="middle"
      font-size="9"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
      fill-opacity="0.78"
    >
      Immutable infra: DB, Redis, secrets, CORS…
    </text>
    <path
      d="M340 60 L372 60"
      stroke="currentColor"
      stroke-width="1.5"
      fill="none"
      marker-end="url(#as-arr)"></path>
    <rect
      x="380"
      y="36"
      width="52"
      height="48"
      rx="5"
      fill="currentColor"
      fill-opacity="0.05"
      stroke="currentColor"
      stroke-width="1"
      stroke-dasharray="3 2"></rect>
    <text
      x="406"
      y="64"
      text-anchor="middle"
      font-size="9"
      font-weight="600"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
    >
      FastAPI
    </text>
    <text
      x="406"
      y="78"
      text-anchor="middle"
      font-size="8"
      font-family="var(--sl-font, system-ui)"
      fill="currentColor"
      fill-opacity="0.8"
    >
      main
    </text>
  </svg>
  <p class="diagram-caption">
    Runtime feature flags and tier defaults live in <strong>global_settings</strong> (DB), not
    <code>AppSettings</code> — see module docstring in{' '}
    <code>cadence/core/config.py</code>.
  </p>
</div>

<style>
  @layer starlight.components {
    .diagram-wrap {
      color: var(--sl-color-gray-2);
      margin: 0.75rem 0 1.25rem;
    }

    .diagram-svg {
      display: block;
      width: 100%;
      max-width: 32rem;
      height: auto;
    }

    .diagram-caption {
      margin: 0.5rem 0 0;
      font-size: var(--sl-text-sm);
      color: var(--sl-color-gray-4);
      max-width: 36rem;
    }

    .diagram-caption code {
      font-size: 0.92em;
    }
  }
</style>
